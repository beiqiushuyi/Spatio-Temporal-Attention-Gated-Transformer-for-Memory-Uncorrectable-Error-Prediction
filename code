# ========== STIM模型类 ==========
class SimplifiedSTIMModel(object):
    """STIM模型类 - """
    
    def __init__(self, config: STIMConfig):
        self.config = config
        self.train_data_path = config.train_data_path
        self.test_data_path = config.test_data_path
        self.device = torch.device(config.device)
        
        # 使用的模型
        self.model = SimplifiedSTIMTransformer(config).to(self.device)
        
        # 优化器设置
        self.optimizer = torch.optim.AdamW(
            self.model.parameters(), 
            lr=config.learning_rate,
            weight_decay=0.005,
            eps=1e-8,
            betas=(0.9, 0.999)
        )
        
        # 学习率调度器
        self.scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(
            self.optimizer, 
            mode='min',
            factor=0.95,        # 更温和的衰减
            patience=8,        # 更有耐心
            verbose=True,
            min_lr=1e-7       # 更低的最小学习率
        )
        
        # 损失函数
        self.criterion = ImprovedFocalLoss(
            alpha=config.focal_alpha, 
            gamma=config.focal_gamma, 
            reduction='mean',
            use_dynamic_alpha=config.use_dynamic_alpha,  #   从配置读取
            min_alpha=config.min_alpha,                  #   从配置读取  
            max_alpha=config.max_alpha  
        )
        
        # 早停机制
        self.early_stopping = EarlyStopping(
            patience=config.early_stopping_patience,
            min_delta=config.early_stopping_min_delta,
            mode='max'
        )
        
        # 数据存储
        self.train_sequences = None
        self.train_labels = None
        self.train_metadata = None
        self.val_sequences = None
        self.val_labels = None
        self.val_loader = None
        
        # 训练历史
        self.train_history = {
            'train_loss': [], 'train_f1': [], 'train_precision': [], 'train_recall': [],
            'val_loss': [], 'val_f1': [], 'val_precision': [], 'val_recall': [],
            'learning_rate': [], 'grad_norm': []
        }
        
        # 稳定训练参数
        self.gradient_clip_norm = 0.5    
        print(f"   学习率: {config.learning_rate:.2e}")
        print(f"   梯度裁剪: {self.gradient_clip_norm}")
        self._test_data_cache = None
        self._prediction_cache = None
        self._cache_loaded = False
    def save_model(self, save_path: str = None):
        """保存训练好的模型"""
        if save_path is None:
            # 创建带时间戳的模型保存路径
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            save_path = f"/home/cgh723412/内存预测/saved_models/stim_model_{timestamp}.pth"
        
        # 确保保存目录存在
        os.makedirs(os.path.dirname(save_path), exist_ok=True)
        
        # 保存模型状态和配置
        save_dict = {
            'model_state_dict': self.model.state_dict(),
            'optimizer_state_dict': self.optimizer.state_dict(),
            'scheduler_state_dict': self.scheduler.state_dict(),
            'config': self.config.__dict__,
            'train_history': self.train_history,
            'best_f1_score': self.early_stopping.best_score,
            'current_epoch': len(self.train_history['train_loss']) if self.train_history['train_loss'] else 0,
            'model_class': 'SimplifiedSTIMTransformer'
        }
        
        torch.save(save_dict, save_path)
        print(f"  模型已保存到: {save_path}")
        print(f"   最佳F1得分: {self.early_stopping.best_score:.4f}")
        print(f"   训练轮数: {save_dict['current_epoch']}")
        
        return save_path

    def load_model(self, load_path: str):
        """加载训练好的模型"""
        if not os.path.exists(load_path):
            raise FileNotFoundError(f"模型文件不存在: {load_path}")
        
        print(f"  正在加载模型: {load_path}")
        
        # 加载保存的数据
        checkpoint = torch.load(load_path, map_location=self.device)
        
        # 验证模型类型
        if checkpoint.get('model_class') != 'SimplifiedSTIMTransformer':
            print(" 警告: 模型类型可能不匹配")
        
        # 加载模型状态
        self.model.load_state_dict(checkpoint['model_state_dict'])
        self.optimizer.load_state_dict(checkpoint['optimizer_state_dict'])
        self.scheduler.load_state_dict(checkpoint['scheduler_state_dict'])
        
        # 恢复训练历史
        self.train_history = checkpoint['train_history']
        
        # 恢复早停状态
        self.early_stopping.best_score = checkpoint['best_f1_score']
        
        print(f"  模型加载成功!")
        print(f"   模型类型: {checkpoint.get('model_class', '未知')}")
        print(f"   最佳F1得分: {checkpoint['best_f1_score']:.4f}")
        print(f"   训练轮数: {checkpoint['current_epoch']}")
        print(f"   当前学习率: {self.get_current_lr():.2e}")
        
        return checkpoint

    @classmethod
    def load_pretrained_model(cls, load_path: str, config: STIMConfig = None):
        """类方法：直接加载预训练模型"""
        if not os.path.exists(load_path):
            raise FileNotFoundError(f"模型文件不存在: {load_path}")
        
        # 先加载检查点获取配置
        checkpoint = torch.load(load_path, map_location='cpu')
        
        if config is None:
            # 从保存的文件中恢复配置
            saved_config_dict = checkpoint['config']
            config = STIMConfig(**saved_config_dict)
            print("📋 从保存文件中恢复配置")
        
        # 创建模型实例
        model = cls(config)
        
        # 加载模型
        model.load_model(load_path)
        
        return model

