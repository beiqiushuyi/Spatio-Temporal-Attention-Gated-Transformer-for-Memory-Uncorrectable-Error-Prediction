    def evaluate_predictions(self, prediction_dict, eval_true_tickets, eval_start, eval_end, window_days=7):

        """
        修复的评估函数 - 精确率和召回率都考虑时间窗口
        """
        if len(eval_true_tickets) == 0:
            return {'precision': 0.0, 'recall': 0.0, 'f1': 0.0, 
                    'true_count': 0, 'pred_count': len(prediction_dict), 'correct_count': 0}

        true_sn_set = set(eval_true_tickets['sn_name'].unique())
        window_seconds = window_days * 86400

        # 修复1：统一计算真正例（TP）- 既要SN匹配，又要时间窗口匹配
        true_positive_count = 0
        true_positive_sn_set = set()

        # 遍历所有真实故障SN
        for sn in true_sn_set:
            if sn in prediction_dict:
                true_time = eval_true_tickets[eval_true_tickets['sn_name'] == sn]['alarm_time'].values[0]

                # 检查是否有预测在时间窗口内
                for pred_time in prediction_dict[sn]:
                    if (true_time - window_seconds) <= pred_time <= true_time:
                        true_positive_count += 1
                        true_positive_sn_set.add(sn)
                        break  # 一个SN只计算一次

        #  修复2：精确率也考虑时间窗口
        predicted_sn_set = set(prediction_dict.keys())

        # 召回率：在真实故障中，有多少被正确预测（时间窗口内）
        recall = true_positive_count / len(true_sn_set) if len(true_sn_set) > 0 else 0.0

        # 精确率：在预测中，有多少是真正的故障（时间窗口内）
        precision = true_positive_count / len(predicted_sn_set) if len(predicted_sn_set) > 0 else 0.0

        # F1得分
        f1 = (2 * precision * recall) / (precision + recall) if (precision + recall) > 0 else 0.0

        return {
            'precision': precision,
            'recall': recall, 
            'f1': f1,
            'true_count': len(true_sn_set),
            'pred_count': len(predicted_sn_set),
            'correct_count': true_positive_count,
            'true_positive_sn_count': len(true_positive_sn_set)  # 新增
        }
