    def predict(self, threshold: float = 0.6) -> Dict[str, List]:
        """使用指定阈值进行预测"""
        proba_result = self.predict_proba()
        
        result = {} 
        for sn, pred_list in proba_result.items():
            timestamps = []
            for pred in pred_list:
                if pred['probability'] >= threshold:
                    timestamps.append(pred['timestamp'])
            
            if timestamps:
                result[sn] = timestamps
        
        return result
    
