class EarlyStopping:
    """早停机制类"""
    
    def __init__(self, patience=15, min_delta=0.001, mode='max'):
        self.patience = patience
        self.min_delta = min_delta
        self.mode = mode
        self.best_score = None
        self.epochs_no_improve = 0
        self.should_stop = False
        self.best_model_state = None
        
    def __call__(self, score, model):
        if self.best_score is None:
            self.best_score = score
            self.best_model_state = model.state_dict().copy()
            return False
            
        if self.mode == 'max':
            improved = score > self.best_score + self.min_delta
        else:
            improved = score < self.best_score - self.min_delta
            
        if improved:
            self.best_score = score
            self.epochs_no_improve = 0
            self.best_model_state = model.state_dict().copy()
        else:
            self.epochs_no_improve += 1
            
        if self.epochs_no_improve >= self.patience:
            self.should_stop = True
            
        return self.should_stop

class ImprovedFocalLoss(nn.Module):
    """Focal Loss，增加数值稳定性 + α"""
    
    def __init__(self, alpha=0.6, gamma=1.5, reduction='mean', eps=1e-8, 
                 use_dynamic_alpha=True, min_alpha=0.25, max_alpha=0.75):
        super(ImprovedFocalLoss, self).__init__()
        self.alpha = alpha  # 备用固定值
        self.gamma = gamma
        self.reduction = reduction
        self.eps = eps
        
        # 新增动态α参数
        self.use_dynamic_alpha = use_dynamic_alpha
        self.min_alpha = min_alpha
        self.max_alpha = max_alpha
        
    def forward(self, inputs, targets):
        inputs = torch.clamp(inputs, min=-10, max=10)
        probs = torch.sigmoid(inputs)
        probs = torch.clamp(probs, min=self.eps, max=1-self.eps)
        
        ce_loss = -(targets * torch.log(probs) + (1 - targets) * torch.log(1 - probs))
        p_t = probs * targets + (1 - probs) * (1 - targets)
        p_t = torch.clamp(p_t, min=self.eps, max=1-self.eps)
        
        #  关键修改：动态计算alpha_t
        if self.use_dynamic_alpha:
            # 计算当前批次的样本分布
            batch_size = targets.size(0)
            pos_count = targets.sum().float()
            neg_count = batch_size - pos_count
            
            # 动态α = 负样本比例（给正样本更多权重）
            if batch_size > 0:
                dynamic_alpha = neg_count / batch_size
                # 限制α的范围，避免极端值
                dynamic_alpha = torch.clamp(dynamic_alpha, 
                                          min=self.min_alpha, 
                                          max=self.max_alpha)
            else:
                dynamic_alpha = torch.tensor(self.alpha).to(targets.device)
            
            # 应用动态α
            alpha_t = dynamic_alpha * targets + (1 - dynamic_alpha) * (1 - targets)
        else:
            # 使用固定α（原来的方式）
            alpha_t = self.alpha * targets + (1 - self.alpha) * (1 - targets)
        
        focal_weight = (1 - p_t) ** self.gamma
        focal_loss = alpha_t * focal_weight * ce_loss
        
        if self.reduction == 'mean':
            return focal_loss.mean()
        elif self.reduction == 'sum':
            return focal_loss.sum()
        else:
            return focal_loss

# ========== 的位置编码（）==========
class SimplifiedPositionalEncoding(nn.Module):
    def __init__(self, d_model=64, seq_len=72):
        super().__init__()
        self.d_model = d_model
        self.dropout = nn.Dropout(0.2)
        
        self.temporal_pe = self.create_stable_temporal_encoding(seq_len, d_model)
        self.spatial_pe = self.create_stable_spatial_encoding(d_model)
        
    def create_stable_temporal_encoding(self, seq_len, d_model):
        pe = torch.zeros(seq_len, d_model)
        position = torch.arange(0, seq_len).unsqueeze(1).float()
        
        div_term = torch.exp(torch.arange(0, d_model, 2).float() * 
                           -(math.log(10000.0) / d_model))
        
        pe[:, 0::2] = torch.sin(position * div_term)  # 移除0.1
        pe[:, 1::2] = torch.cos(position * div_term)  # 移除0.1
        
        return nn.Parameter(pe, requires_grad=False)
    
    def create_stable_spatial_encoding(self, d_model):
        spatial_encodings = []
        
        for row in range(4):
            for col in range(8):
                pos_encoding = torch.zeros(d_model)
                
                if d_model >= 2:
                    pos_encoding[:d_model//2] = row / 4.0  # 移除0.1
                    pos_encoding[d_model//2:] = col / 8.0  # 移除0.1
                
                spatial_encodings.append(pos_encoding)
        
        spatial_pe = torch.stack(spatial_encodings)
        return nn.Parameter(spatial_pe, requires_grad=True)
    
    def forward(self, bit_features, micro_features):
        batch_size, seq_len = bit_features.shape[:2]
        device = bit_features.device
        
        temporal_enc = self.temporal_pe.to(device).unsqueeze(0).unsqueeze(2)
        spatial_enc = self.spatial_pe.to(device).unsqueeze(0).unsqueeze(0)
        
        # 标准Transformer做法：直接相加
        bit_encoded = bit_features + temporal_enc + spatial_enc
        micro_encoded = micro_features + temporal_enc
        
        return self.dropout(bit_encoded), self.dropout(micro_encoded)
class FusedSpatioTemporalLayer(nn.Module):
    """
    单层融合时空注意力（优化版）
    处理流程：空间attention → 时间attention → 序列级门控 → FFN
    """
    
    def __init__(self, d_model=64, num_heads=2):
        super().__init__()
        self.d_model = d_model
        
        # 空间注意力（带mask）
        self.spatial_attn = nn.MultiheadAttention(
            embed_dim=d_model,
            num_heads=max(1, num_heads//2),
            batch_first=True,
            dropout=0.2
        )
        
        # 时间注意力
        self.temporal_attn = nn.MultiheadAttention(
            embed_dim=d_model,
            num_heads=num_heads,
            batch_first=True,
            dropout=0.2
        )
        
        # LayerNorm（）
        self.norm2 = nn.LayerNorm(d_model, eps=1e-6)  # 时间attention用
        self.norm3 = nn.LayerNorm(d_model, eps=1e-6)  # FFN用
        
        # FFN（一个）
        self.ffn = nn.Sequential(
            nn.Linear(d_model, d_model),
            nn.GELU(),
            nn.Dropout(0.2),
            nn.Linear(d_model, d_model),
            nn.Dropout(0.2)
        )
        
        # 序列级门控（基于整个时空序列）
        self.gate_network = nn.Sequential(
            nn.Linear(d_model, d_model // 2),
            nn.ReLU(),
            nn.Dropout(0.2),
            nn.Linear(d_model // 2, 1),
            nn.Sigmoid()
        )
        
        self._init_weights()
    
    def _init_weights(self):
        """权重初始化"""
        for module in self.modules():
            if isinstance(module, nn.Linear):
                nn.init.xavier_uniform_(module.weight, gain=0.3)
                if module.bias is not None:
                    nn.init.zeros_(module.bias)
        
        # 门控初始化：bias=0 → sigmoid(0)=0.5 → exp(0)=1.0
        final_layer = self.gate_network[-2]
        nn.init.zeros_(final_layer.weight)
        nn.init.constant_(final_layer.bias, 0.0)
    
    def exponential_gate_transform(self, gate_score):
        """指数门控变换: G(L) ∈ [0,1] → exp(G(L) - 0.5)"""
        return torch.exp(gate_score - 0.5)
    
    def apply_spatial_attention(self, features, spatial_mask):
        """
        对每个时间步应用空间attention

        """
        batch_size, seq_len, num_spatial, d_model = features.shape
        spatial_list = []
        
        for t in range(seq_len):
            feat_t = features[:, t, :, :]  # [batch, 32, d_model]
            attn_out, _ = self.spatial_attn(feat_t, feat_t, feat_t, attn_mask=spatial_mask)
            spatial_list.append(attn_out)
        
        spatial_out = torch.stack(spatial_list, dim=1)  
        return spatial_out
    
    def apply_temporal_attention(self, features):
        """
        对每个空间位置应用时间attention

        """
        batch_size, seq_len, num_spatial, d_model = features.shape
        
   
        features_transposed = features.transpose(1, 2)
        temporal_list = []
        
        for s in range(num_spatial):
            feat_s = features_transposed[:, s, :, :]  
            attn_out, _ = self.temporal_attn(feat_s, feat_s, feat_s)
            temporal_list.append(attn_out)
        

        temporal_out = torch.stack(temporal_list, dim=1).transpose(1, 2)
        return temporal_out
    
    def forward(self, features, spatial_mask):
        """

        """
        # Step 1: 空间attention（无norm，无残差）
        spatial_out = self.apply_spatial_attention(features, spatial_mask)
        spatial_out = torch.clamp(spatial_out, min=-3.0, max=3.0)
        
        # Step 2: 时间attention（Pre-Norm + 残差）
        temporal_attn_out = self.apply_temporal_attention(spatial_out)  # 先计算attention
        temporal_out = spatial_out + 0.1 * self.norm2(temporal_attn_out)  # Pre-Norm + 残差
        temporal_out = torch.clamp(temporal_out, min=-3.0, max=3.0)
        
        # Step 3: 序列级门控（基于完整的时空特征）
        global_feat = temporal_out.mean(dim=[1, 2])  # [batch, d_model]
        gate_score = self.gate_network(global_feat)  # [batch, 1]
        gate_weight = self.exponential_gate_transform(gate_score)  # [batch, 1]
        
        # Step 4: FFN（Pre-Norm + 门控调节的残差）
        ffn_out = self.ffn(temporal_out)  # 先计算FFN
        final_out = temporal_out + gate_weight.view(-1, 1, 1, 1) * self.norm3(ffn_out)  # Pre-Norm + 门控残差
        final_out = torch.clamp(final_out, min=-3.0, max=3.0)
        
        return final_out


# ========== 多层融合时空注意力 ==========
class FusedSpatioTemporalAttention(nn.Module):
    """
    多层融合时空注意力模块（bit特征专用）
    包含num_layers层FusedSpatioTemporalLayer
    """
    
    def __init__(self, d_model=64, num_heads=2, num_layers=2):
        super().__init__()
        self.d_model = d_model
        self.num_layers = num_layers
        
        # 多层时空attention
        self.layers = nn.ModuleList([
            FusedSpatioTemporalLayer(d_model, num_heads) 
            for _ in range(num_layers)
        ])
        
        print(f"  融合时空注意力初始化:")
        print(f"   层数: {num_layers}")
    
    def create_spatial_mask(self, device):
        """创建4×8空间邻接mask"""
        mask = torch.zeros(32, 32, device=device)
        
        for i in range(4):      
            for j in range(8):  
                pos = i * 8 + j  
                neighbors = [pos]  
                if i > 0: neighbors.append((i-1) * 8 + j)      
                if i < 3: neighbors.append((i+1) * 8 + j)      
                if j > 0: neighbors.append(i * 8 + (j-1))      
                if j < 7: neighbors.append(i * 8 + (j+1))      
                
                for neighbor in neighbors:
                    mask[pos, neighbor] = 1
                    
        return (mask == 0)  # 返回bool mask（True表示mask掉）
    
    def forward(self, bit_features):
        """

        """
        device = bit_features.device
        spatial_mask = self.create_spatial_mask(device)
        
        current_features = bit_features
        
        # 多层处理
        for layer_idx, layer in enumerate(self.layers):
            current_features = layer(current_features, spatial_mask)
        
        return current_features


# ========== 改进的双重注意力块（使用融合时空注意力）==========
class ImprovedDualAttentionBlock(nn.Module):
    """
    双重注意力机制
    - bit特征: 使用融合时空注意力（FusedSpatioTemporalAttention）
    - micro特征: 使用时间注意力（_apply_temporal_attention）
    """
    
    def __init__(self, d_model=64, num_heads=2, num_spatial_layers=2):
        super().__init__()
        self.d_model = d_model
        self.num_spatial_layers = num_spatial_layers
        
        # bit特征用融合时空注意力
        self.fused_spatiotemporal_attn = FusedSpatioTemporalAttention(
            d_model=d_model, 
            num_heads=num_heads, 
            num_layers=num_spatial_layers
        )
        
        # micro特征用时间注意力
        self.temporal_attn = nn.MultiheadAttention(
            embed_dim=d_model,
            num_heads=num_heads,
            batch_first=True,
            dropout=0.2
        )
        
        # LayerNorm（时间注意力用）
        self.norm3 = nn.LayerNorm(d_model, eps=1e-6)
        self.norm4 = nn.LayerNorm(d_model, eps=1e-6)
        
        # 时间注意力的FFN
        self.ffn = nn.Sequential(
            nn.Linear(d_model, d_model),
            nn.GELU(),
            nn.Dropout(0.2),
            nn.Linear(d_model, d_model),
            nn.Dropout(0.2)
        )
        
        self._init_weights()
        
    def _init_weights(self):
        """权重初始化"""
        for module in self.modules():
            if isinstance(module, nn.Linear):
                nn.init.xavier_uniform_(module.weight, gain=0.3)
                if module.bias is not None:
                    nn.init.zeros_(module.bias)
    
    def forward(self, bit_features, micro_features):
        """

        """
        # === 1. bit特征：融合时空注意力 ===
        enhanced_bit_features = self.fused_spatiotemporal_attn(bit_features)
        
        # === 2. micro特征：时间注意力 ===
        final_micro_features = self._apply_temporal_attention(micro_features)
        
        return enhanced_bit_features, final_micro_features
    
    def _apply_temporal_attention(self, features):
        """

        batch_size, seq_len, num_features, d_model = features.shape
        features_reshaped = features.permute(0, 2, 1, 3).contiguous()
        temporal_list = []
        
        for f in range(num_features):
            feature_seq = features_reshaped[:, f, :, :]  # [batch, 72, d_model]
            
            temporal_out, _ = self.temporal_attn(feature_seq, feature_seq, feature_seq)
            temporal_out = self.norm3(feature_seq + 0.1 * temporal_out)
            
            # FFN
            ffn_out = self.ffn(temporal_out)
            temporal_out = self.norm4(temporal_out + 0.1 * ffn_out)
            
            temporal_list.append(temporal_out)
        
        final_features = torch.stack(temporal_list, dim=2)
        return final_features

# ========== STransformer ==========
class SimplifiedSTIMTransformer(nn.Module):
    """ Transformer -"""
    
    def __init__(self, config: STIMConfig):
        super(SimplifiedSTIMTransformer, self).__init__()
        
        self.config = config
        self.d_model = config.d_model
        self.sequence_length = config.observation_hours
        
        # 输入标准化
        self.input_norm = nn.LayerNorm(44, eps=1e-6)
        
        # 特征投影层
        self.bit_embeddings = nn.ModuleList([
            nn.Sequential(
                nn.Linear(1, self.d_model),
                nn.LayerNorm(self.d_model)  
            ) for _ in range(32)
        ])
        
        self.micro_embeddings = nn.ModuleList([
            nn.Sequential(
                nn.Linear(1, self.d_model),
                nn.LayerNorm(self.d_model)  
            ) for _ in range(12)
        ])
        
        # 位置编码
        self.positional_encoding = SimplifiedPositionalEncoding(
            d_model=self.d_model, 
            seq_len=self.sequence_length
        )
        
        # 注意力层
        self.dual_attention_layers = nn.ModuleList([
            ImprovedDualAttentionBlock(self.d_model, config.num_heads, config.num_spatial_layers) 
            for _ in range(config.num_layers)
        ])
        
        # 特征融合（直接拼接）
        self.feature_fusion = nn.Sequential(
            nn.LayerNorm(self.d_model*2, eps=1e-6),
            nn.Linear(self.d_model * 2, self.d_model),
            nn.GELU(),
            nn.Dropout(config.dropout),
            nn.LayerNorm(self.d_model, eps=1e-6)
        )
        
        # # 简单的最终编码器
        # encoder_layer = nn.TransformerEncoderLayer(
        #     d_model=self.d_model,
        #     nhead=config.num_heads,
        #     dim_feedforward=self.d_model,
        #     dropout=config.dropout,
        #     activation='gelu',
        #     batch_first=True,
        #     norm_first=True
        # )
        # self.final_encoder = nn.TransformerEncoder(encoder_layer, num_layers=1)
        
        # 分类器
        self.classifier = nn.Sequential(
            nn.LayerNorm(self.d_model, eps=1e-6),
            nn.Dropout(config.dropout),
            nn.Linear(self.d_model, self.d_model // 4),
            nn.GELU(),
            nn.Dropout(config.dropout),
            nn.Linear(self.d_model // 4, 1)
        )
        
        # 权重初始化
        self._init_weights_conservatively()
        
    def _create_stable_projection(self, input_dim, output_dim):
        """创建数值稳定的投影层"""
        layer = nn.Linear(input_dim, output_dim)
        nn.init.xavier_uniform_(layer.weight, gain=1.0)
        nn.init.zeros_(layer.bias)
        return layer
    
    def _init_weights_conservatively(self):
        """保守的权重初始化"""
        for module in self.modules():
            if isinstance(module, nn.Linear):
                nn.init.xavier_uniform_(module.weight, gain=0.3)
                if module.bias is not None:
                    nn.init.zeros_(module.bias)
        
        # 分类器特殊处理
        positive_ratio = 0.2
        initial_bias = np.log(positive_ratio / (1 - positive_ratio))
        
        classifier_final = self.classifier[-1]
        nn.init.normal_(classifier_final.weight, mean=0, std=0.005)
        nn.init.constant_(classifier_final.bias, initial_bias)
        
        print(f"🔧 模型初始化: 分类器bias={initial_bias:.3f}")
    
    def reorder_features(self, x):
        """重排特征"""
        bit_features = x[:, :, :32]
        micro_features = x[:, :, 32:]
        return bit_features, micro_features
    
    def project_features_safely(self, bit_features, micro_features):
        """安全的特征投影"""
        batch_size, seq_len = bit_features.shape[:2]
        
        # 投影bit特征
        bit_projected_list = []
        for bit_idx in range(32):
            bit_single = bit_features[:, :, bit_idx:bit_idx+1]
            bit_embedded = self.bit_embeddings[bit_idx](bit_single)
            bit_embedded = torch.clamp(bit_embedded, min=-4.0, max=4.0)
            bit_projected_list.append(bit_embedded)
        
        bit_projected = torch.stack(bit_projected_list, dim=2)
        
        # 投影微观特征
        micro_projected_list = []
        for micro_idx in range(12):
            micro_single = micro_features[:, :, micro_idx:micro_idx+1]
            micro_embedded = self.micro_embeddings[micro_idx](micro_single)
            micro_embedded = torch.clamp(micro_embedded, min=-6.0, max=6.0)
            micro_projected_list.append(micro_embedded)
        
        micro_projected = torch.stack(micro_projected_list, dim=2)
        
        return bit_projected, micro_projected
    
    def forward(self, x):
        batch_size, seq_len, _ = x.shape
        
        # 输入标准化
        x = self.input_norm(x)
        
        # 特征重排和投影
        bit_features, micro_features = self.reorder_features(x)
        bit_projected, micro_projected = self.project_features_safely(bit_features, micro_features)
        
        # 位置编码
        bit_encoded, micro_encoded = self.positional_encoding(bit_projected, micro_projected)
        
        # 双重注意力处理
        current_bit_features = bit_encoded
        current_micro_features = micro_encoded
        
        for layer in self.dual_attention_layers:
            current_bit_features, current_micro_features = layer(
                current_bit_features, current_micro_features
            )
            
            # 每层后裁剪数值范围
            current_bit_features = torch.clamp(current_bit_features, min=-3.0, max=3.0)
            current_micro_features = torch.clamp(current_micro_features, min=-3.0, max=3.0)
        
        # 特征融合（直接拼接）
        fused_features = []
        for t in range(seq_len):
            bit_t = current_bit_features[:, t, :, :].mean(dim=1)  # 平均池化
            micro_t = current_micro_features[:, t, :, :].mean(dim=1)  # 平均池化
            
            # 直接拼接（不用注意力）
            combined_t = torch.cat([bit_t, micro_t], dim=1)
            fused_t = self.feature_fusion(combined_t)
            fused_t = torch.clamp(fused_t, min=-2.0, max=2.0)
            fused_features.append(fused_t)
        
        fused_sequence = torch.stack(fused_features, dim=1)
        
        # 最终序列建模
        # final_output = self.final_encoder(fused_sequence)
        
        # 池化和分类
        # pooled = final_output.mean(dim=1)
        pooled = fused_sequence.mean(dim=1)  #   直接使用 fused_sequence

        output = self.classifier(pooled)
        
        # 最终输出裁剪
        output = torch.clamp(output, min=-5.0, max=5.0)
        
        return output.squeeze(-1)

# ========== 数据生成器和数据集类（保持不变）==========
class STIMDataGenerator(metaclass=abc.ABCMeta):
    """STIM数据生成器基类"""
    
    def __init__(self, config: STIMConfig):
        self.config = config
        self.feature_path = self.config.feature_path
        self.train_data_path = self.config.train_data_path
        self.test_data_path = self.config.test_data_path
        self.ticket_path = self.config.ticket_path
        
        # 时间戳转换
        self.train_start_date = self._datetime_to_timestamp(self.config.train_date_range[0])
        self.train_end_date = self._datetime_to_timestamp(self.config.train_date_range[1])
        self.test_start_date = self._datetime_to_timestamp(self.config.test_data_range[0])
        self.test_end_date = self._datetime_to_timestamp(self.config.test_data_range[1])
        
        # 读取故障票据
        ticket_full = pd.read_csv(self.ticket_path)
        print(f"完整故障票据总数: {len(ticket_full)}")
        

        # 创建目录
        os.makedirs(self.config.train_data_path, exist_ok=True)
        os.makedirs(self.config.test_data_path, exist_ok=True)
    
    @staticmethod
    def _datetime_to_timestamp(date: str) -> int:
        """将 %Y-%m-%d 格式的日期转换为时间戳"""
        return int(datetime.strptime(date, "%Y-%m-%d").timestamp())
    
    def fix_feature_order(self, feature_columns):
        """修复特征顺序，确保bit特征按正确顺序排列"""
        bit_features = []
        micro_features = []
        
        for col in feature_columns:
            if col.startswith('bit_'):
                bit_features.append(col)
            else:
                micro_features.append(col)
        
        # 按正确顺序排列bit特征
        bit_features_sorted = []
        for i in range(32):
            bit_name = f'bit_{i}'
            if bit_name in bit_features:
                bit_features_sorted.append(bit_name)
        
        micro_features.sort()
        correct_order = bit_features_sorted + micro_features
        
        return correct_order
    
    def _load_stim_sequences(self, sn_file: str, stride: int = 24) -> Tuple[List[np.ndarray], List[int], List[str]]:
        """加载STIM连续时间序列"""
        try:
            if sn_file.endswith('.feather'):
                data = pd.read_feather(os.path.join(self.feature_path, sn_file))
            else:
                data = pd.read_csv(os.path.join(self.feature_path, sn_file))
            
            if data.empty or 'LogTime' not in data.columns or 'sn_name' not in data.columns:
                return [], [], []
            
            data = data.sort_values('LogTime').reset_index(drop=True)
            
            meta_columns = ['LogTime', 'sn_name']
            feature_columns = [col for col in data.columns if col not in meta_columns]
            feature_columns = self.fix_feature_order(feature_columns)
            
            if len(feature_columns) != 44:
                print(f"警告: {sn_file} 特征数量不是44个，是{len(feature_columns)}个")
                return [], [], []
            
            sequences = []
            timestamps = []
            sn_names = []
            
            observation_hours = self.config.observation_hours
            
            for i in range(0, len(data) - observation_hours + 1, stride):
                window_data = data.iloc[i:i + observation_hours]
                
                time_diffs = np.diff(window_data['LogTime'].values)
                if not np.all(time_diffs == 3600):
                    continue
                
                sequence = window_data[feature_columns].values.astype(np.float32)
                
                if sequence.shape == (observation_hours, len(feature_columns)):
                    sequences.append(sequence)
                    timestamps.append(int(window_data['LogTime'].iloc[-1]))
                    sn_names.append(window_data['sn_name'].iloc[0])
            
            return sequences, timestamps, sn_names
        
        except Exception as e:
            print(f"Error loading {sn_file}: {e}")
            return [], [], []
    
    def _get_data(self) -> Tuple[List[np.ndarray], List[int], List[str]]:
        """获取所有数据"""
        file_list = os.listdir(self.feature_path)
        file_list = [x for x in file_list if x.endswith("_stim_modified.feather") or x.endswith("_stim_modified.csv")]
        file_list.sort()
        
        all_sequences = []
        all_timestamps = []
        all_sn_names = []
        
        if self.config.USE_MULTI_PROCESS:
            worker_num = self.config.WORKER_NUM
            with Pool(worker_num) as pool:
                results = list(tqdm(
                    pool.imap(self._process_file, file_list),
                    total=len(file_list),
                    desc="Processing STIM files"
                ))
            
            for sequences, timestamps, sn_names in results:
                all_sequences.extend(sequences)
                all_timestamps.extend(timestamps)
                all_sn_names.extend(sn_names)
        else:
            for file in tqdm(file_list, desc="Processing STIM files"):
                sequences, timestamps, sn_names = self._process_file(file)
                all_sequences.extend(sequences)
                all_timestamps.extend(timestamps)
                all_sn_names.extend(sn_names)
        
        return all_sequences, all_timestamps, all_sn_names
    
    @abc.abstractmethod
    def _process_file(self, sn_file):
        """处理单个文件，子类需要实现"""
        raise NotImplementedError("Subclasses should implement this method")
    
    @abc.abstractmethod
    def generate_and_save_data(self):
        """生成并保存数据，子类需要实现"""
        raise NotImplementedError("Subclasses should implement this method")

class STIMSequenceDataset(Dataset):
    """STIM时序数据集"""
    
    def __init__(self, sequences, labels=None):
        self.sequences = sequences
        self.labels = labels
        self._validate_and_preprocess_data()
        
    def _validate_and_preprocess_data(self):
        """改进的数据预处理""" 
        print("验证数据质量...")
        valid_sequences = []
        valid_labels = [] if self.labels is not None else None
        
        for i, seq in enumerate(self.sequences):
            # 处理异常值
            seq = np.nan_to_num(seq, nan=0.0, posinf=2.0, neginf=-2.0)
            
            # 逐特征标准化
            for feature_idx in range(seq.shape[1]):
                feature_data = seq[:, feature_idx]
                feature_mean = feature_data.mean()
                feature_std = feature_data.std()
                
                if feature_std > 1e-6:
                    seq[:, feature_idx] = (feature_data - feature_mean) / feature_std
                else:
                    seq[:, feature_idx] = 0
            
            # 更严格的数值范围限制
            seq = np.clip(seq, -2.0, 2.0)
            
            # 最终检查
            if np.any(np.isnan(seq)) or np.any(np.isinf(seq)):
                continue
                
            valid_sequences.append(seq.astype(np.float32))
            if self.labels is not None:
                valid_labels.append(self.labels[i])
        
        self.sequences = valid_sequences
        if self.labels is not None:
            self.labels = valid_labels
        
        print(f"  处理后有效序列数: {len(self.sequences)}")
        
        # 统计预处理后的数据分布
        if self.sequences:
            all_data = np.concatenate([seq.flatten() for seq in self.sequences[:100]])
            print(f"预处理后数据分布: min={all_data.min():.3f}, max={all_data.max():.3f}, "
                f"mean={all_data.mean():.3f}, std={all_data.std():.3f}")
        
    def __len__(self):
        return len(self.sequences)
    
    def __getitem__(self, idx):
        sequence = torch.FloatTensor(self.sequences[idx])
        
        if self.labels is not None:
            label = torch.FloatTensor([self.labels[idx]])
            return sequence, label
        else:
            return sequence

