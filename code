def get_real_gpu_memory():
    """通过nvidia-smi获取真实的GPU内存使用情况"""
    try:
        result = subprocess.run(['nvidia-smi', '--query-gpu=index,name,memory.total,memory.used,memory.free', 
                               '--format=csv,noheader,nounits'], 
                               capture_output=True, text=True, check=True)
        
        gpu_info = []
        for line in result.stdout.strip().split('\n'):
            if line.strip():
                parts = [x.strip() for x in line.split(',')]
                gpu_id = int(parts[0])
                gpu_name = parts[1]
                total_mb = float(parts[2])
                used_mb = float(parts[3]) 
                free_mb = float(parts[4])
                
                total_gb = total_mb / 1024
                used_gb = used_mb / 1024
                free_gb = free_mb / 1024
                
                gpu_info.append((gpu_id, gpu_name, total_gb, used_gb, free_gb))
        
        return gpu_info
    
    except (subprocess.CalledProcessError, FileNotFoundError):
        print(" 无法执行nvidia-smi，回退到torch检测")
        return None

def auto_select_best_gpu_fixed():
    """GPU选择器"""
    if not torch.cuda.is_available():
        print(" CUDA不可用，使用CPU")
        return "cpu"
    
    gpu_info = get_real_gpu_memory()
    
    if gpu_info:
        print(f" 检测到 {len(gpu_info)} 块GPU (nvidia-smi)")
        print("\n 真实GPU显存状态:")
        
        best_gpu = 0
        max_free_memory = 0
        
        for gpu_id, gpu_name, total_gb, used_gb, free_gb in gpu_info:
            usage_percent = (used_gb / total_gb) * 100
            
            print(f"  GPU {gpu_id}: {gpu_name}")
            print(f"    总显存: {total_gb:.1f} GB")
            print(f"    已使用: {used_gb:.1f} GB ({usage_percent:.1f}%)")
            print(f"    可用: {free_gb:.1f} GB")
            
            if free_gb > max_free_memory:
                max_free_memory = free_gb
                best_gpu = gpu_id
            print()
        
        torch.cuda.set_device(best_gpu)
        torch.cuda.empty_cache()
        gc.collect()
        
        device_name = f"cuda:{best_gpu}"
        print(f" 自动选择: GPU {best_gpu}")
        print(f" 设备: {device_name}")
        print(f" 可用显存: {max_free_memory:.1f} GB")

